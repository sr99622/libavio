#!/usr/bin/env bash

USE_SYSTEM_LIBS=0

usage() {
  echo "Usage: $0 [--system-libs] <project directory>" >&2
  exit 1
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage
fi

if [[ $# -eq 2 ]]; then
  if [[ "$1" != "--system-libs" ]]; then
    usage
  fi
  USE_SYSTEM_LIBS=1
  PROJECT_ARG="$2"
else
  PROJECT_ARG="$1"
fi

if [[ ! -d "$PROJECT_ARG" ]]; then
  echo "Project directory $PROJECT_ARG does not exist, please enter a valid directory" >&2
  exit 1
fi

if [[ ! -f "$PROJECT_ARG/pyproject.toml" && ! -f "$PROJECT_ARG/setup.py" ]]; then
  echo "Invalid Python project directory, did not find either pyproject.toml or setup.py in $PROJECT_ARG" >&2
  exit 1
fi

PROJECT_DIR="$(cd "$PROJECT_ARG" && pwd)"
echo "Project Directory: $PROJECT_DIR" >&2

if (( USE_SYSTEM_LIBS )); then
  echo "Using system-installed FFmpeg/SDL libraries" >&2
else
  echo "Using custom FFmpeg/SDL libraries" >&2
fi

#PROJECT_DIR="$PWD/$1"
#echo "Project Directory: $PROJECT_DIR" >&2

TMP=$(uname -m)
if [[ "$TMP" == "x86_64" ]] || [[ "$TMP" == "amd64" ]] || [[ "$TMP" == "i386" ]] || [[ "$TMP" == "i686" ]]; then
  echo "processor architecture is x86"
  ARCHITECTURE="x86_64"
elif [[ "$TMP" == "aarch64" ]] || [[ "$TMP" == "arm64" ]] || [[ "$TMP" == "arm"* ]]; then
  echo "proocessor architecture is aarch64"
  ARCHITECTURE="aarch64"
else
  echo "Unknown processor architecture: $TMP"
  ARCHITECTURE="UNKNOWN"
fi
export ARCH=$ARCHITECTURE

BASE="$PWD"
export LD_RUN_PATH='$ORIGIN'

if (( ! USE_SYSTEM_LIBS )); then
  dnf install -y wget nasm
  export SOURCE="$BASE/source"
  export BUILD="$BASE/build"
  export BIN="$BASE/usr/local/bin"
  export ACLOCAL_PATH=/usr/share/aclocal
  export PKG_CONFIG_PATH="$BUILD/lib/pkgconfig"
  export SDL2_DIR="$BUILD"
  export DIR_NAME="$(cd "$(dirname "$0")" && pwd)"
  "$DIR_NAME/build_libs"
fi

first_pass=1
venvs=("py314")
#venvs=("py310" "py311" "py312" "py313" "py314")
for venv in "${venvs[@]}"; do
  echo "Python venv: $venv" >&2
  if [ ! -d "$BASE/$venv" ]; then
    version="${venv:2}"
    version="${version:0:1}.${version:1}"
    echo "version $version"
    python${version} -m venv $BASE/$venv
    . $BASE/$venv/bin/activate
    pip install --upgrade pip
    deactivate
  fi
  source "$BASE/$venv/bin/activate"
  python --version
  first_pass=0

  pip install build auditwheel patchelf
  cd $PROJECT_DIR
  python -m build

  if [[ "$ARCH" == "x86_64" ]]; then
    echo "processor architecture is x86"
    auditwheel repair dist/*.whl --plat manylinux_2_35_x86_64
  elif [[ "$ARCH" == "aarch64" ]]; then
    echo "aarch64"
    auditwheel repair dist/*.whl --plat manylinux_2_28_aarch64
  else
    echo "ERROR: UNABLE TO BUILD WHEEL - Unknown architecture"
  fi

  deactivate
done
